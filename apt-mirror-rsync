#!/bin/perl

# Program     : apt-mirror-rsync
# Version     : 1.10
# Author      : Mark : mark at ibiblio dot org
# Created     : 2026-05-29
# Updated     : 2026-07-06
# Purpose     : Tool to rsync remote APT repositories to local disk.
#               Enhanced per-repo config, statistics and monitoring.

$CONF_FILE = "/etc/apt/apt-mirror-rsync.conf";
$testing = 0;
if ($ARGV[0] eq '--test') {
    $CONF_FILE = "/etc/apt/apt-mirror-rsync.conf.test";
    $testing++;
}
&read_conf_file;

# Ensure variables are populated, otherwise things will break.
if (not length($LOGFILE))          { die "ERR: variable LOGFILE empty"; }
if (not length($RSYNC_CONFIG_DIR)) { die "ERR: variable RSYNC_CONFIG_DIR empty"; }
if (not length($DIST_WORK_DIR))    { die "ERR: variable DIST_WORK_DIR empty"; }
if (not length($APT_MIRROR_DIR))   { die "ERR: variable APT_MIRROR_DIR empty"; }
if (not length($FILE_OWNERSHIP))   { die "ERR: variable FILE_OWNERSHIP empty"; }
if ($FILE_OWNERSHIP !~ m/\w+:\w+/) { die "ERR: variable FILE_OWNERSHIP incorrect"; } # Must be user:group

&log("apt-mirror-rsync started");

# Make any missing directories, happens on the first run
`mkdir -p $RSYNC_CONFIG_DIR`;
`mkdir -p $APT_MIRROR_DIR`;
`mkdir -p ${DIST_WORK_DIR}/work_files`;

use Data::Dumper;
$Data::Dumper::Sortkeys = 1;
$Data::Dumper::Indent = 1;
### Useful, but not installed by default. See `corelist -v v5.39.5`
### use Devel::Size qw(size total_size);
$start_sec = time;
$debug = 0;
$debug_files = 0;
$debug_rsync = 0;
$dry_run = 0;
$verbose = 0;
$progress = 0;
$dist_stat = 0;
$force = 0;
$list = 0;
$show_times = 0;
$skip_zero = 0;
$skip_mirror = 0;
$dist_stat_repo = "";
$config = 0;
$config_mirror = "";
$remove = 0;
$remove_repo = "";
$argc = scalar @ARGV;
%REPOS = ();
$EXCLUDE_DIST_COPY{'example.com'} = 1;
# proxmox keeps 22 dist files and 8133 binary deb files in dists.
$SPECIAL_DIST_COPY{'download.proxmox.com'} = 1;
foreach $exe ('rsync', 'gunzip', 'xzcat') {
    my $exe_check = `which ${exe}`;
    chomp($exe_check);
    if ($exe_check =~ m/not found/) { &error("${exe} not installed"); }
}
&parse_args;
&reset_logfile($LOGFILE);
&import_configs($RSYNC_CONFIG_DIR);
if (not $skip_mirror) {
    if (not scalar keys %REPOS) {
        &error("No configuration supplied in ${RSYNC_CONFIG_DIR}");
    }
    foreach my $remote_host (sort keys %REPOS) {
        next if (defined($EXCLUDE_DIST_COPY{$remote_host}));
        &process_rsync_mirror_config_file($remote_host, "normal");
    }
} else {
    if ($config)    { &show_configs("show", $config_mirror); }
    if ($list)      { &show_configs("list"); }
    if ($dist_stat) { &dist_stat($dist_stat_repo); }
    if ($remove)    { print STDOUT "Not yet implemented\n"; }
}
my $end_sec = time;
my $time_taken_pretty = &sec_to_dhms($end_sec - $start_sec);
if ($debug) { &log("DEBUG: exiting normally. Time taken is ${time_taken_pretty}."); }
if ($progress && (not $skip_mirror)) {
    my $time_now = "";
    if ($show_times) { $time_now = &ymdhms_timestamp . " "; }
    print STDOUT "${time_now}Finished all mirroring after ${time_taken_pretty}\n";
}
exit(0);

